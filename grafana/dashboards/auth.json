{

    "title": "Auth Service Dashboard",
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "HTTP Requests Rate",
        "type": "graph",
        "targets": [{
          "expr": "rate(auth_http_requests_total[5m])",
          "legendFormat": "{{method}} {{endpoint}} - {{status}}"
        }]
      },
      {
        "title": "gRPC Requests Rate",
        "type": "graph",
        "targets": [{
          "expr": "rate(auth_grpc_requests_total[5m])",
          "legendFormat": "{{method}} - {{status}}"
        }]
      },
      {
        "title": "Registrations Rate",
        "type": "stat",
        "targets": [{
          "expr": "rate(auth_registrations_total[1h])"
        }]
      },
      {
        "title": "Logins Rate",
        "type": "stat",
        "targets": [{
          "expr": "rate(auth_logins_total[1h])"
        }]
      },
      {
        "title": "Logins by Type",
        "type": "piechart",
        "targets": [{
          "expr": "auth_logins_by_type"
        }]
      },
      {
        "title": "Active Sessions",
        "type": "stat",
        "targets": [{
          "expr": "auth_active_sessions_total"
        }]
      },
      {
        "title": "Token Validation Rate",
        "type": "graph",
        "targets": [{
          "expr": "rate(auth_token_validations_total[5m])"
        }]
      },
      {
        "title": "Token Validation Errors",
        "type": "graph",
        "targets": [{
          "expr": "rate(auth_token_validation_errors_total[5m])",
          "legendFormat": "{{error_type}}"
        }]
      },
      {
        "title": "Token Operations",
        "type": "stat",
        "targets": [
          {"expr": "rate(auth_access_tokens_issued_total[1h])", "legendFormat": "Access Tokens"},
          {"expr": "rate(auth_refresh_tokens_issued_total[1h])", "legendFormat": "Refresh Tokens"},
          {"expr": "rate(auth_tokens_revoked_total[1h])", "legendFormat": "Revoked Tokens"}
        ]
      },
      {
        "title": "Active Goroutines",
        "type": "graph",
        "targets": [{
          "expr": "auth_goroutines_current"
        }]
      }
    ]
  }
